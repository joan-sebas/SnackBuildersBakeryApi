# =====================================================================
# Snack Builders Bakery — Environment Variables
# Copy this file to .env and adjust as needed. .env is not committed.
# =====================================================================

# ---------- Database ----------
POSTGRES_USER=bakery
POSTGRES_PASSWORD=bakery_dev
POSTGRES_DB=bakery
POSTGRES_PORT=5432

# Full connection string (overrides individual settings if set)
DATABASE_URL=postgresql+asyncpg://bakery:bakery_dev@db:5432/bakery

# ---------- API ----------
API_PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# ---------- Aging Algorithm ----------
# How many minutes of waiting reduce effective priority by AGING_FACTOR
AGING_THRESHOLD_MINUTES=15
AGING_FACTOR=1.0

# ---------- Payment Mock ----------
# Probability (0.0 - 1.0) of simulated payment failure
PAYMENT_MOCK_FAILURE_RATE=0.0
# Simulated latency for card payments (milliseconds)
PAYMENT_MOCK_LATENCY_MS=200

# ---------- Rate Limiting ----------
RATE_LIMIT=100/minute

# ---------- CORS ----------
CORS_ORIGINS=*
